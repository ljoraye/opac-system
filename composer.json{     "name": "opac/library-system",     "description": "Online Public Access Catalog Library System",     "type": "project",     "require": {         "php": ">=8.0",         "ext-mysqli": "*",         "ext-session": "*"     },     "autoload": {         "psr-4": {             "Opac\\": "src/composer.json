{
    "name": "opac/library-system",
    "description": "Online Public Access Catalog Library System",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-mysqli": "*",
        "ext-session": "*"
    },
    "autoload": {
        "psr-4": {
            "Opac\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
