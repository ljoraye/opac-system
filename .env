# Database Configuration (Render will provide these)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=opac_db

# Render Database URLs (uncomment and use these on Render)
# DATABASE_URL=postgresql://user:password@host:port/database
# For MySQL on Render: mysql://user:password@host:port/database

# Admin Configuration
ADMIN_PASSWORD=opac123

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app-name.onrender.com

# Session Configuration
SESSION_LIFETIME=7200

# Error Reporting (production settings)
ERROR_REPORTING=E_ALL & ~E_DEPRECATED & ~E_STRICT
DISPLAY_ERRORS=0

# Render-specific settings
PORT=10000
# Render will set PORT automatically, this is fallback
