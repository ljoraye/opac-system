# Database Configuration (Render will provide these)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=opac_db

# Render Database Connection (uncomment for production)
# RENDER_DB_HOST=your-db-host.render.com
# RENDER_DB_USER=opac_user
# RENDER_DB_PASSWORD=your-generated-password
# RENDER_DB_NAME=opac_db

# Admin Configuration
ADMIN_PASSWORD=opac123

# Application Settings
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app-name.onrender.com

# Session Configuration
SESSION_LIFETIME=7200

# Error Reporting (production settings)
ERROR_REPORTING=E_ALL & ~E_DEPRECATED & ~E_STRICT
DISPLAY_ERRORS=0
